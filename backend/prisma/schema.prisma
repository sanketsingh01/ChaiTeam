generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  role             userRole          @default(USER)
  createdAT        DateTime          @default(now())
  updatedAT        DateTime          @updatedAt
  accessToken      String?
  image            String?
  isVerified       Boolean           @default(true)
  refreshToken     String?
  provider         String?
  isInGroup        Boolean           @default(false)
  groupMember      GroupMember?
  groupsLeader     Groups?           @relation("GroupLeader")
  joinApplications JoinApplication?
  notices          NoticeBoard[]     
  userActivities   UserActivity[]    
  groupActivities  GroupActivity[]   @relation("GroupActivityUser")
  batchActivities  BatchActivity[]   @relation("BatchActivityUser")
  targetGroupActivities GroupActivity[] @relation("TargetUserRelation")
  targetBatchActivities BatchActivity[] @relation("BatchTargetUserRelation")
  performedBatchActivities BatchActivity[] @relation("PerformerRelation")

  @@map("users")
}

model BatchMember {
  id      String @id @default(uuid())
  userId  String
  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  @@map("batch_members")
}

model Batch {
  id           String        @id @default(uuid())
  name         String
  createdAT    DateTime      @default(now())
  updatedAT    DateTime      @updatedAt
  status       status        @default(ACTIVE)
  description  String?
  batchMembers BatchMember[]
  groups       Groups[]
  batchActivities BatchActivity[]

  @@map("batches")
}

model Groups {
  id               String            @id @default(uuid())
  name             String
  description      String?
  tags             Json?
  leader_id        String            @unique
  createdAT        DateTime          @default(now())
  updatedAT        DateTime          @updatedAt
  disbanded_at     DateTime?
  disbanded_reason String?
  visible_to_users Boolean           @default(true)
  status           groupStatus       @default(ACTIVE)
  batchId          String
  batchName        String
  capacity         Int
  member           GroupMember[]
  batch            Batch             @relation(fields: [batchId], references: [id])
  leader           User              @relation("GroupLeader", fields: [leader_id], references: [id])
  joinApplications JoinApplication[]
  notices          NoticeBoard[]     
  groupActivities  GroupActivity[]

  @@map("groups")
}

model GroupMember {
  id      String          @id @default(uuid())
  userId  String          @unique
  groupId String
  name    String
  email   String
  role    groupMemberRole
  group   Groups          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id])

  @@map("group_members")
}

model JoinApplication {
  id        String            @id @default(uuid())
  userId    String            @unique
  groupId   String
  reason    String
  status    applicationStatus @default(PENDING)
  createdAT DateTime          @default(now())
  updatedAT DateTime          @updatedAt
  email     String
  name      String
  group     Groups            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])

  @@map("join_applications")
}

model NoticeBoard {
  id          String       @id @default(uuid())
  groupId     String
  userId      String
  type        NoticeType
  message     String?
  createdAT   DateTime     @default(now())
  updatedAT   DateTime     @updatedAt
  is_edited   Boolean      @default(false)
  status      NoticeStatus @default(ACTIVE)

  group Groups @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id])

  @@map("noticeboard")
}

model UserActivity {
  id           String         @id @default(uuid())
  userId       String
  activityType UserActivityType
  description  String
  metadata     Json?
  createdAt    DateTime       @default(now())
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activities")
}

model GroupActivity {
  id           String          @id @default(uuid())
  groupId      String
  userId       String
  activityType GroupActivityType
  description  String
  targetUserId String?
  metadata     Json?
  createdAt    DateTime        @default(now())
  isSystemGenerated Boolean    @default(false)

  group      Groups @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User   @relation("GroupActivityUser", fields: [userId], references: [id])
  targetUser User?  @relation("TargetUserRelation", fields: [targetUserId], references: [id])

  @@map("group_activities")
}

model BatchActivity {
  id           String          @id @default(uuid())
  batchId      String
  userId       String?
  activityType BatchActivityType
  description  String
  targetUserId String?
  performedBy  String?
  metadata     Json?
  createdAt    DateTime        @default(now())
  isMilestone  Boolean         @default(false)

  batch      Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user       User? @relation("BatchActivityUser", fields: [userId], references: [id])
  targetUser User? @relation("BatchTargetUserRelation", fields: [targetUserId], references: [id])
  performer  User? @relation("PerformerRelation", fields: [performedBy], references: [id])

  @@map("batch_activities")
}

model SystemActivity {
  id           String            @id @default(uuid())
  activityType SystemActivityType
  description  String
  metadata     Json?
  createdAt    DateTime          @default(now())
  severity     SystemSeverity    @default(INFO)
  component    String
  requiresAttention Boolean      @default(false)

  @@map("system_activities")
}

enum userRole {
  USER
  ADMIN
  LEADER
}

enum groupMemberRole {
  LEADER
  MEMBER
}

enum status {
  ACTIVE
  INACTIVE
  COMPLETED
}

enum groupStatus {
  ACTIVE
  INACTIVE
  PRIVATE
  FULL
  DISBANDED
}

enum applicationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum NoticeType {
  CHAT
  NOTIFICATION
  PINNED_CHAT
  SYSTEM
}

enum NoticeStatus {
  ACTIVE
  DELETED
}

enum UserActivityType {
  USER_ONBOARDED
  USER_PROFILE_UPDATED
  USER_LOGIN
  USER_LOGOUT
  BATCH_JOINED
  BATCH_LEFT
  PASSWORD_RESET_REQUESTED
  USER_REACTIVATED
}

enum GroupActivityType {
  GROUP_CREATED
  GROUP_JOINED
  GROUP_LEFT
  MEMBER_KICKED
  LEADERSHIP_CHANGED
  GROUP_DISBANDED
  JOIN_REQUEST_SENT
  JOIN_REQUEST_APPROVED
  JOIN_REQUEST_REJECTED
  GROUP_SETTINGS_UPDATED
}

enum BatchActivityType {
  BATCH_CREATED
  BATCH_UPDATED
  BATCH_ARCHIVED
  USER_ADDED
  USER_REMOVED
  DEADLINE_CREATED
  ANNOUNCEMENT_POSTED
  GROUP_FORMED
  BATCH_COMPLETED
}

enum SystemActivityType {
  SYSTEM_STARTUP
  SYSTEM_SHUTDOWN
  BACKUP_COMPLETED
  MAINTENANCE_STARTED
  MAINTENANCE_COMPLETED
  DATABASE_MIGRATION
  SECURITY_ALERT
  PERFORMANCE_ALERT
}

enum SystemSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}